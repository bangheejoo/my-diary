rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 공통 헬퍼 ──────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // 두 uid가 친구 관계(accepted)인지 확인
    function isFriend(uid1, uid2) {
      let fid = uid1 < uid2 ? uid1 + '_' + uid2 : uid2 + '_' + uid1;
      return exists(/databases/$(database)/documents/friendships/$(fid)) &&
             get(/databases/$(database)/documents/friendships/$(fid)).data.status == 'accepted';
    }

    // ── nicknames (공개 읽기 - 비로그인 중복체크용) ────────────────
    match /nicknames/{nickname} {
      allow read: if true;  // 누구나 읽기 가능 (닉네임만 저장)
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // ── users ───────────────────────────────────────────────────
    match /users/{uid} {
      // 본인만 생성/수정
      allow create: if isSignedIn() && isOwner(uid);
      allow update: if isSignedIn() && isOwner(uid);

      // 로그인한 사용자 모두 읽기 가능 (닉네임/이메일 검색용)
      allow read: if isSignedIn();

      // 삭제 불가
      allow delete: if false;
    }

    // ── posts ───────────────────────────────────────────────────
    match /posts/{postId} {
      // 작성: 로그인한 본인
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.visibility in ['private', 'friends']
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.recordDate is string;

      // 수정/삭제: 본인만
      allow update, delete: if isSignedIn() && isOwner(resource.data.uid);

      // 읽기:
      //   - 본인 기록은 항상 가능
      //   - 친구공개 기록은 친구만 가능
      allow read: if isSignedIn() && (
        isOwner(resource.data.uid) ||
        (resource.data.visibility == 'friends' && isFriend(request.auth.uid, resource.data.uid))
      );
    }

    // ── friendships ─────────────────────────────────────────────
    match /friendships/{friendshipId} {
      // 생성: 로그인 + 본인이 requester
      allow create: if isSignedIn()
        && request.resource.data.requesterId == request.auth.uid
        && request.resource.data.receiverId != request.auth.uid
        && request.auth.uid in request.resource.data.users
        && request.resource.data.status == 'pending';

      // 수정: 관계 당사자만 (수락/거절)
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.users;

      // 삭제: 관계 당사자 중 한 명
      allow delete: if isSignedIn()
        && request.auth.uid in resource.data.users;

      // 읽기: 관계 당사자 또는 로그인한 사용자 (친구 상태 확인용)
      allow read: if isSignedIn();
    }

    // ── notifications ───────────────────────────────────────────
    match /notifications/{notifId} {
      // 생성: 로그인한 사용자 (friendService 에서 자동 생성)
      allow create: if isSignedIn();

      // 읽기: 수신자 본인만
      allow read: if isSignedIn() && isOwner(resource.data.toUid);

      // 수정(읽음 처리): 수신자 본인만
      allow update: if isSignedIn()
        && isOwner(resource.data.toUid)
        && request.resource.data.keys().hasOnly(['read'])
        || request.auth.uid in [resource.data.toUid, resource.data.fromUid];

      // 삭제 불가
      allow delete: if false;
    }
  }
}
